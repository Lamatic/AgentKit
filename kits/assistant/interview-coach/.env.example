# ─────────────────────────────────────────────
# Lamatic Flow Configuration
# ─────────────────────────────────────────────

# Your Lamatic project endpoint
# Find it: API Docs → App Frameworks → LAMATIC_PROJECT_ENDPOINT
LAMATIC_PROJECT_ENDPOINT="YOUR_PROJECT_ENDPOINT"

# Your Lamatic Flow ID
# Find it: API Docs → App Frameworks → LAMATIC_FLOW_ID
LAMATIC_FLOW_ID="YOUR_FLOW_ID"

# Your Lamatic Project ID
# Find it: API Docs → App Frameworks → LAMATIC_PROJECT_ID
LAMATIC_PROJECT_ID="YOUR_PROJECT_ID"

# Your Lamatic API Key
# Find it: Settings → API Keys → Copy
LAMATIC_PROJECT_API_KEY="YOUR_API_KEY"