# Your Lamatic API key
LAMATIC_API_KEY="your_lamatic_api_key_here"

# Your Lamatic project endpoint
LAMATIC_ENDPOINT="https://your-project.lamatic.ai/api/flows"

# The Flow ID of your Warehouse Analyst flow
LAMATIC_FLOW_ID="your_flow_id_here"

# ─────────────────────────────────────────
# PostgreSQL Database
# ─────────────────────────────────────────

# Your default PostgreSQL connection string
# Users can also set a custom one from the settings panel in the UI
DATABASE_URL="postgresql://username:password@host:5432/database_name"
#if the default database connection dont work then use the pooling connection url