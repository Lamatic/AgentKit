        "values": {
          "id": "codeNode_652",
          "code": "// Assign the value you want to return from this code node to `output`. \n// The `output` variable is already declared.\n\ntry {\n    // 1. Parse the AI response\n    const parsed = JSON.parse({{LLMNode_802.output.generatedResponse}});\n    \n    // 2. Build the Action Items HTML list manually\n    const actionItemsHtml = parsed.actionItems.map(item => `\n        <li style=\"margin-bottom: 10px; padding: 8px; border-left: 4px solid #2563eb; background: #f9fafb; list-style: none;\">\n            <strong>${item.task}</strong><br/>\n            <small style=\"color: #666;\">👤 ${item.owner} | 📅 ${item.deadline}</small>\n        </li>\n    `).join('');\n\n    // 3. Build the Decisions HTML list manually\n    const decisionsHtml = parsed.decisions.map(d => `<li>${d}</li>`).join('');\n\n    // 4. Send everything to the output\n    output = {\n        summary: parsed.summary || \"No summary\",\n        emailBody: `\n            <p>${parsed.summary}</p>\n            <h4>✅ Action Items</h4>\n            <ul style=\"padding: 0;\">${actionItemsHtml}</ul>\n            <h4>🔨 Decisions</h4>\n            <ul>${decisionsHtml}</ul>\n        `\n    };\n} catch (e) {\n    output = { \n        summary: \"Error parsing AI response\", \n        emailBody: \"<p>Check logs for parsing error.</p>\" \n    };\n}\n",
          "nodeName": "Code"
        }
