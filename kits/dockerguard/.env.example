# DockerGuard — required environment variables
# Copy this file to apps/.env.local and fill in real values from Lamatic Studio.

# Flow ID of the deployed "dockerguard-audit" flow (Studio → Flow → Details → Flow ID)
DOCKERGUARD_AUDIT="your-dockerguard-audit-flow-id"

# Lamatic API credentials (Studio → Settings → API Keys / API Docs)
LAMATIC_API_URL="https://your-project.lamatic.workers.dev/api"
LAMATIC_PROJECT_ID="your-project-id"
LAMATIC_API_KEY="your-api-key"
