# Lamatic project credentials (Studio → Settings / API)
LAMATIC_API_URL="https://your-project.lamatic.ai/api/graphql"
LAMATIC_API_KEY="your-api-key-here"
LAMATIC_PROJECT_ID="your-project-id-here"

# Optional: Set this to a deployed flow ID to run it by default from the CLI without passing an ID
FLOWBENCH_DEMO_FLOW_ID="your-deployed-demo-flow-id-here"
