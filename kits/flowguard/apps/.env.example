# ── Lamatic connection (server-side only, never sent to the client) ──
LAMATIC_API_KEY=YOUR_API_KEY
LAMATIC_PROJECT_ID=YOUR_PROJECT_ID
LAMATIC_API_URL=https://your-project.lamatic.dev/graphql

# ── FlowGuard's own flows (one deployed flow id each) ──
FLOW_ID_SUITE_GENERATOR=YOUR_SUITE_GENERATOR_FLOW_ID
FLOW_ID_JUDGE=YOUR_JUDGE_FLOW_ID
FLOW_ID_REPORT_SUMMARIZER=YOUR_REPORT_SUMMARIZER_FLOW_ID

# ── Optional: red-team module (leave blank to disable the Red-Team tab) ──
FLOW_ID_RED_TEAM_GENERATOR=YOUR_RED_TEAM_GENERATOR_FLOW_ID

# ── Optional: the demo "victim" flow FlowGuard evaluates in the walkthrough ──
# Any deployed flow id works here; this is just a convenient default target.
FLOW_ID_DEMO_VICTIM=YOUR_DEMO_VICTIM_FLOW_ID
