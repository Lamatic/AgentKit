{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IssuePilot Planning Output",
  "description": "Structured engineering planning output generated by the IssuePilot workflow.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "analysis",
    "planning",
    "review",
    "report"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version for the planning output."
    },

    "analysis": {
      "type": "object",
      "description": "Issue understanding and requirement extraction.",
      "additionalProperties": false,
      "required": [
        "summary",
        "businessGoal",
        "requirements",
        "missingInformation",
        "clarifyingQuestions"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "description": "High-level summary of the GitHub issue."
        },
        "businessGoal": {
          "type": "string",
          "description": "Primary business objective."
        },
        "requirements": {
          "type": "array",
          "description": "Functional requirements extracted from the issue.",
          "minItems": 0,
          "items": {
            "type": "string"
          }
        },
        "missingInformation": {
          "type": "array",
          "description": "Information required before implementation.",
          "minItems": 0,
          "items": {
            "type": "string"
          }
        },
        "clarifyingQuestions": {
          "type": "array",
          "description": "Questions that should be answered before development.",
          "minItems": 0,
          "items": {
            "type": "string"
          }
        }
      }
    },

    "planning": {
      "type": "object",
      "description": "Engineering implementation plan.",
      "additionalProperties": false,
      "required": [
        "technicalApproach",
        "alternativeApproach",
        "assumptions",
        "tasks",
        "timeline"
      ],
      "properties": {
        "technicalApproach": {
          "type": "string",
          "description": "Recommended implementation approach."
        },
        "alternativeApproach": {
          "type": "string",
          "description": "Alternative implementation approach."
        },
        "assumptions": {
          "type": "array",
          "description": "Engineering assumptions.",
          "minItems": 0,
          "items": {
            "type": "string"
          }
        },
        "tasks": {
          "type": "object",
          "description": "Implementation tasks grouped by engineering domain.",
          "additionalProperties": false,
          "required": [
            "backend",
            "frontend",
            "database",
            "testing",
            "deployment"
          ],
          "properties": {
            "backend": {
              "type": "array",
              "minItems": 0,
              "items": {
                "type": "string"
              }
            },
            "frontend": {
              "type": "array",
              "minItems": 0,
              "items": {
                "type": "string"
              }
            },
            "database": {
              "type": "array",
              "minItems": 0,
              "items": {
                "type": "string"
              }
            },
            "testing": {
              "type": "array",
              "minItems": 0,
              "items": {
                "type": "string"
              }
            },
            "deployment": {
              "type": "array",
              "minItems": 0,
              "items": {
                "type": "string"
              }
            }
          }
        },
        "timeline": {
          "type": "object",
          "description": "Estimated effort for implementation.",
          "additionalProperties": false,
          "required": [
            "backend",
            "frontend",
            "testing",
            "deployment",
            "total"
          ],
          "properties": {
            "backend": {
              "type": "string"
            },
            "frontend": {
              "type": "string"
            },
            "testing": {
              "type": "string"
            },
            "deployment": {
              "type": "string"
            },
            "total": {
              "type": "string"
            }
          }
        }
      }
    },

    "review": {
      "type": "object",
      "description": "Engineering review and quality assessment.",
      "additionalProperties": false,
      "required": [
        "risks",
        "sprintBlockers",
        "acceptanceCriteria",
        "definitionOfDone",
        "sprintReadiness",
        "confidence"
      ],
      "properties": {
        "risks": {
          "type": "array",
          "description": "Potential implementation risks.",
          "minItems": 0,
          "items": {
            "type": "string"
          }
        },
        "sprintBlockers": {
          "type": "array",
          "description": "Issues preventing implementation.",
          "minItems": 0,
          "items": {
            "type": "string"
          }
        },
        "acceptanceCriteria": {
          "type": "array",
          "description": "Conditions required for successful completion.",
          "minItems": 0,
          "items": {
            "type": "string"
          }
        },
        "definitionOfDone": {
          "type": "array",
          "description": "Checklist indicating feature completion.",
          "minItems": 0,
          "items": {
            "type": "string"
          }
        },
        "sprintReadiness": {
          "type": "object",
          "description": "Readiness assessment for sprint planning.",
          "additionalProperties": false,
          "required": [
            "score",
            "status",
            "recommendation"
          ],
          "properties": {
            "score": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            "status": {
              "type": "string"
            },
            "recommendation": {
              "type": "string"
            }
          }
        },
        "confidence": {
          "type": "object",
          "description": "Confidence in the generated plan.",
          "additionalProperties": false,
          "required": [
            "score",
            "reason"
          ],
          "properties": {
            "score": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            "reason": {
              "type": "string"
            }
          }
        }
      }
    },

    "report": {
      "type": "object",
      "description": "Final report representation.",
      "additionalProperties": false,
      "required": [
        "markdown",
        "checklist"
      ],
      "properties": {
        "markdown": {
          "type": "string",
          "description": "Markdown version of the engineering report."
        },
        "checklist": {
          "type": "array",
          "description": "Final implementation checklist.",
          "minItems": 0,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}