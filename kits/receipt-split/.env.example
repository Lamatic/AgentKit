# Credentials for calling the deployed flows via the Lamatic API/SDK.
# Get these from Lamatic Studio: Settings -> API Keys / Project / API Docs.
# Flow IDs: Studio -> flow -> three-dot menu -> Copy Flow Id
BILL_SPLITTER_FLOW_ID=YOUR_BILL_SPLITTER_FLOW_ID
LAMATIC_API_KEY=YOUR_API_KEY
LAMATIC_API_URL=YOUR_API_ENDPOINT
LAMATIC_PROJECT_ID=YOUR_PROJECT_ID
RECEIPT_EXTRACT_FLOW_ID=YOUR_RECEIPT_EXTRACT_FLOW_ID
