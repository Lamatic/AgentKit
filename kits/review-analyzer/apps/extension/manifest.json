{
  "manifest_version": 3,
  "name": "Review Analyzer Agent",
  "version": "1.0",
  "description": "Analyze product reviews on e-commerce sites to summarize consensus, extract pros & cons, and determine a trust score.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Review Analyzer"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
