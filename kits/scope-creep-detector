    retries: '0'
    webhookUrl: ''
    retry_delay: '0'
    outputMapping: |-
      {
        "output": "{{LLMNode_985.output.generatedResponse}}"
      }
  needs:
    - LLMNode_985
  modes: {}
  schema: {}
