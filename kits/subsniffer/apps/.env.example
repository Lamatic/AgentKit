# Lamatic project credentials — copy from Lamatic Studio → Settings → API Keys / Project
LAMATIC_API_URL="https://api.lamatic.ai"
LAMATIC_PROJECT_ID="YOUR_LAMATIC_PROJECT_ID"
LAMATIC_API_KEY="YOUR_LAMATIC_API_KEY"

# The deployed SubSniffer flow ID — Lamatic Studio → open the deployed flow → Flow ID
SUBSNIFFER_FLOW_ID="YOUR_SUBSNIFFER_FLOW_ID"
