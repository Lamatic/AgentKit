# Support-to-Engineering Bug Bridge - Environment Configuration

# === Generative AI (Groq) ===
# Required. Free tier limits (30 RPM) apply. Ensure fetch window overlap mitigates spikes.
# Note: Raw ticket text (which may contain PII) is sent to Groq. Groq's API-tier data policy
# states they do not train on API inputs and use a 30-day transient log for abuse monitoring.
GROQ_API_KEY=gsk_your_groq_api_key_here

# === Embeddings (Hugging Face) ===
# Required for sentence-transformers/all-MiniLM-L6-v2 (dim 384) to vectorize ticket text.
# Scope: Requires a free Read token.
# Data Policy: Hugging Face does not use payloads sent to the Inference API to train their models.
# This aligns with the Phase 3 PII stance for ticket text.
HF_TOKEN=hf_your_huggingface_token_here

# === Lamatic ===
# Required for triggering the flow and writing to the vector store.
LAMATIC_API_URL=https://api.lamatic.ai/v1
LAMATIC_API_KEY=lamatic_your_api_key_here

# === GitHub Integrations ===
# Fine-grained PAT required for repository issue/label management.
GITHUB_TOKEN=github_pat_your_token_here
GITHUB_REPO_OWNER=your-org
GITHUB_REPO_NAME=your-repo

# === Zendesk Polling ===
# Read-only access for ticket polling.
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=support@yourdomain.com
ZENDESK_API_TOKEN=your_zendesk_api_token

# === Agent Settings ===
# The minimum confidence score (0.0 to 1.0) required to merge a ticket into a cluster.
# Below this threshold, the ticket is held for human review.
BUG_BRIDGE_CONFIDENCE_THRESHOLD=0.70

# The number of minutes into the past Zendesk should be polled on every run.
# A 10-minute fetch on a 5-minute cron ensures overlap to prevent dropped events during rate limits.
BUG_BRIDGE_FETCH_WINDOW_MINS=10
