# Required environment variables for the Bug Bridge Dashboard
# Copy to .env.local and fill in values before running.

# Lamatic project credentials (same account as the main flow)
LAMATIC_API_URL=https://api.lamatic.ai/v1
LAMATIC_PROJECT_ID=lamatic_your_project_id_here
LAMATIC_API_KEY=lamatic_your_api_key_here

# The Flow ID of the bug-bridge-list-flow created in Lamatic Studio.
# REQUIRED BEFORE RUNNING: this flow does not auto-exist.
# See README.md > Deployment > Step 2 for setup instructions.
BUG_BRIDGE_LIST_FLOW_ID=your_bug_bridge_list_flow_id

# GitHub org/repo for constructing issue links (read-only, no token needed)
NEXT_PUBLIC_GITHUB_REPO_OWNER=your-org
NEXT_PUBLIC_GITHUB_REPO_NAME=your-repo

# Optional: override base URL for the internal /api/clusters fetch
# Default: http://localhost:3000
# NEXT_PUBLIC_BASE_URL=https://your-deployment-url.com
